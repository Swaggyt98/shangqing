<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:padding="8sp"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_weight="1"
            android:layout_height="wrap_content">
            <CheckBox
                android:id="@+id/ck_dachuxue"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="大出血"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_xiuke"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="休克"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_qixiong"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="气胸"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_qixinghuai"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="气性坏疽"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_weight="1"
            android:layout_height="wrap_content">
            <CheckBox
                android:id="@+id/ck_zhixi"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="窒息"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_choucu"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="抽搐"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_jiezhi"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="截瘫"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/btnstyle"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="wrap_content"
            android:text="其他："
            android:gravity="center"
            android:layout_height="match_parent"/>
        <EditText
            android:id="@+id/other"
            android:layout_width="100sp"
            android:layout_height="match_parent"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/cancel"
            android:layout_width="wrap_content"
            android:text="关闭"
            android:layout_margin="3sp"
            android:background="@color/serial1"
            android:layout_height="30sp"/>

        <Button
            android:id="@+id/confirm"
            android:layout_width="wrap_content"
            android:text="确认"
            android:layout_margin="3sp"
            android:background="@color/bgs6"
            android:layout_height="30sp"/>
    </LinearLayout>

</LinearLayout>