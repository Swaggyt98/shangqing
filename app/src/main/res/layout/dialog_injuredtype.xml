<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:padding="8sp"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:layout_height="wrap_content">
            <CheckBox
                android:id="@+id/ck_zhashang"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="炸伤"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_runqi"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="刃器伤"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_chongji"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="冲击伤"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_shaoshang"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="烧伤"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_duji"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="毒剂伤"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_shengwu"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="生物武器伤"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_weibo"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="微波损伤"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_height="wrap_content">
            <CheckBox
                android:id="@+id/ck_qiangdan"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="枪弹伤"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_jiya"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="挤压伤"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_zhuangji"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="撞击伤"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_dongshang"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="冻伤"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_dianlifuse"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="电离辐射伤"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_jiguang"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="激光损伤"
                android:layout_height="wrap_content"/>
            <CheckBox
                android:id="@+id/ck_fuhe"
                android:layout_width="match_parent"
                android:background="@drawable/btnstyle"
                android:layout_margin="3sp"
                android:text="复合伤"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/btnstyle"
        android:layout_height="wrap_content">
        <TextView

            android:layout_width="wrap_content"
            android:text="其他："
            android:gravity="center"
            android:layout_height="match_parent"/>
        <EditText
            android:id="@+id/ck_other"
            android:layout_width="100sp"
            android:layout_height="match_parent"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/cancel"
            android:layout_width="wrap_content"
            android:text="关闭"
            android:layout_margin="3sp"
            android:background="@color/serial1"
            android:layout_height="30sp"/>

        <Button
            android:id="@+id/confirm"
            android:layout_width="wrap_content"
            android:text="确认"
            android:layout_margin="3sp"
            android:background="@color/bgs6"
            android:layout_height="30sp"/>
    </LinearLayout>

</LinearLayout>