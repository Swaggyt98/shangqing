<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.home.care.CareFragment">

    <!-- TODO: Update blank fragment layout -->

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:background="@color/bgs1"
            android:padding="3sp"
            android:orientation="horizontal"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:orientation="horizontal"
                android:background="@color/bgs1"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="100sp"
                    android:orientation="vertical"
                    android:padding="2sp"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="match_parent"
                        android:text="姓名"
                        android:textAlignment="center"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/username"
                        android:layout_width="match_parent"
                        android:textAlignment="center"
                        android:textSize="18sp"
                        android:text="姓名"
                        android:background="@drawable/underline"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="150sp"
                    android:orientation="vertical"
                    android:padding="2sp"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="match_parent"
                        android:text="伤员ID"
                        android:textAlignment="center"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/userid"
                        android:layout_width="match_parent"
                        android:textAlignment="center"
                        android:textSize="18sp"
                        android:text="伤员ID"
                        android:background="@drawable/underline"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="80sp"
                    android:orientation="vertical"
                    android:padding="2sp"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="match_parent"
                        android:text="血型"
                        android:textAlignment="center"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/bloodtype"
                        android:layout_width="match_parent"
                        android:textAlignment="center"
                        android:textSize="18sp"
                        android:text="血型"
                        android:background="@drawable/underline"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:layout_marginLeft="20sp"

                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:id="@+id/voiceinput"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="30sp"
                        android:src="@drawable/microphone"
                        android:layout_height="30sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:text="语音录入"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
                <LinearLayout
                    android:id="@+id/pm"
                    android:layout_width="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginLeft="10sp"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="30sp"
                        android:src="@drawable/blood1"
                        android:layout_height="30sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:text="测量血压"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
                <LinearLayout
                    android:id="@+id/setrecheck"
                    android:layout_width="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginLeft="10sp"
                    android:gravity="center"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="30sp"
                        android:src="@drawable/tag"
                        android:layout_height="30sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:text="标记二检"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
                <LinearLayout
                    android:id="@+id/saveresult"
                    android:layout_width="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginLeft="10sp"
                    android:gravity="center"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="30sp"
                        android:src="@drawable/save"
                        android:layout_height="30sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:text="保存结果"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
                <LinearLayout
                    android:id="@+id/networksetting"
                    android:layout_width="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginLeft="10sp"
                    android:gravity="center"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="30sp"
                        android:src="@drawable/network"
                        android:layout_height="30sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:text="网络设置"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_height="match_parent">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="horizontal"
                    android:padding="5sp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/underline"
                    android:layout_margin="3sp"
                    android:layout_height="match_parent">
                    <TextView
                        android:layout_width="70sp"
                        android:text="抗感染"
                        android:layout_margin="3sp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/anti_infection"
                        android:layout_width="match_parent"
                        android:text="未生成"
                        android:layout_margin="3sp"
                        android:padding="3sp"
                        android:background="@drawable/bluegreenbtn"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="horizontal"
                    android:padding="5sp"
                    android:layout_margin="3sp"
                    android:gravity="center"
                    android:layout_weight="1"
                    android:background="@drawable/underline"
                    android:layout_height="match_parent">
                    <TextView
                        android:layout_width="70sp"
                        android:text="抗休克"
                        android:layout_margin="3sp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/anti_shock"
                        android:layout_width="match_parent"
                        android:text="未生成"
                        android:layout_margin="3sp"
                        android:padding="3sp"
                        android:background="@drawable/bluegreenbtn"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="horizontal"
                    android:padding="5sp"
                    android:layout_margin="3sp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/underline"
                    android:layout_height="match_parent">
                    <TextView
                        android:layout_width="70sp"
                        android:text="紧急手术"
                        android:layout_margin="3sp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/emergency_surgery"
                        android:layout_width="match_parent"
                        android:text="未生成"
                        android:layout_margin="3sp"
                        android:padding="3sp"
                        android:background="@drawable/bluegreenbtn"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="horizontal"
                    android:padding="5sp"
                    android:layout_margin="3sp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/underline"
                    android:layout_height="match_parent">
                    <TextView
                        android:layout_width="70sp"
                        android:text="后送"
                        android:layout_margin="3sp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/evacuation"
                        android:layout_width="match_parent"
                        android:text="未生成"
                        android:layout_margin="3sp"
                        android:padding="3sp"
                        android:background="@drawable/bluegreenbtn"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="horizontal"
                    android:padding="5sp"
                    android:background="@drawable/underline"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:orientation="vertical"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:layout_height="match_parent">
                        <TextView
                            android:layout_width="wrap_content"
                            android:text="是否紧急处置"
                            android:layout_height="wrap_content"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@color/bgs1"
                            android:layout_height="wrap_content">
                            <CheckBox
                                android:id="@+id/wonder_injury"
                                android:layout_width="wrap_content"
                                android:textSize="12sp"
                                android:text="是"
                                android:layout_height="wrap_content"/>
                            <CheckBox
                                android:id="@+id/no_wonder_injury"
                                android:layout_width="wrap_content"
                                android:text="否"
                                android:textSize="12sp"
                                android:checked="true"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_weight="1"
                        android:layout_height="match_parent">
                        <TextView
                            android:layout_width="wrap_content"
                            android:text="当前处置方式"
                            android:layout_height="wrap_content"/>

                        <RadioGroup
                            android:layout_width="wrap_content"
                            android:id="@+id/disposel_type"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@color/bgs1"
                            android:layout_height="wrap_content">

                            <RadioButton
                                android:id="@+id/selfcare"
                                android:layout_width="wrap_content"
                                android:text="自救"
                                android:textSize="12sp"
                                android:checked="true"
                                android:layout_height="wrap_content"/>
                            <RadioButton
                                android:id="@+id/togecare"
                                android:layout_width="wrap_content"
                                android:text="互救"
                                android:textSize="12sp"
                                android:layout_height="wrap_content"/>
                            <RadioButton
                                android:id="@+id/healthcare"
                                android:layout_width="wrap_content"
                                android:text="卫救"
                                android:textSize="12sp"
                                android:layout_height="wrap_content"/>
                            <RadioButton
                                android:id="@+id/uncare"
                                android:layout_width="wrap_content"
                                android:text="未处置"
                                android:textSize="12sp"
                                android:layout_height="wrap_content"/>
                        </RadioGroup>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/underline"
                    android:layout_height="match_parent">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="伤情评估结果及处置方案:"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/dispose_plan"
                        android:layout_width="match_parent"
                        android:lines="20"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:textAlignment="center"
                        android:layout_gravity="center"
                        android:layout_height="match_parent"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_margin="5sp"
                    android:layout_height="wrap_content">
                    <Button
                        android:id="@+id/generatedeal"
                        android:layout_width="match_parent"
                        android:paddingLeft="10sp"
                        android:paddingRight="10sp"
                        android:layout_weight="1"
                        android:background="@drawable/underline"
                        android:text="伤情评估结果及处置建议"
                        android:layout_height="wrap_content"/>
                    <Button
                        android:id="@+id/autofill"
                        android:layout_width="match_parent"
                        android:paddingLeft="10sp"
                        android:paddingRight="10sp"
                        android:layout_weight="1"
                        android:background="@drawable/underline"
                        android:text="智能处置方案生成"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/loadding"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@color/gray_trans"

        android:layout_height="match_parent">

        <ProgressBar
            android:padding="20sp"
            android:visibility="visible"

            android:layout_weight="1"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
        <TextView
            android:layout_width="match_parent"
            android:textSize="50sp"
            android:gravity="center"
            android:text="正在生成处理建议，请稍等..."
            android:layout_height="wrap_content"/>
    </LinearLayout>
</FrameLayout>