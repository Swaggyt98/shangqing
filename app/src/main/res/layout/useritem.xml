<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="230sp"
    android:layout_margin="3sp"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:padding="2sp"
        android:background="@drawable/underline"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:id="@+id/topbar"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:textSize="20sp"
                android:textAlignment="center"
                android:text="设备:"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/deviceid"
                android:layout_width="wrap_content"
                android:textSize="23sp"
                android:textAlignment="center"
                android:text=""
                android:layout_height="wrap_content"/>
            <ImageView
                android:id="@+id/battery_val"
                android:layout_width="50sp"
                android:src="@drawable/ele1"
                android:layout_height="30sp"/>
            <ImageView
                android:id="@+id/selimg"
                android:layout_width="30sp"
                android:layout_gravity="end"
                android:src="@drawable/round2"
                android:layout_height="30sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/userinfo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"
            android:padding="2sp"
            android:background="@drawable/btnstyle2"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:text="伤员信息："
                android:textSize="20sp"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="horizontal"
                    android:padding="1sp"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:textSize="15sp"
                        android:text="ID号:"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/userid"
                        android:layout_width="190dp"
                        android:layout_height="wrap_content"
                        android:text="2846143"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="horizontal"
                    android:padding="2sp"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:textSize="15sp"
                        android:text="姓名:"
                        android:layout_height="wrap_content"/>
                    <EditText
                        android:id="@+id/username"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="请输入姓名"
                        android:textSize="15sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="性别:"
                        android:textSize="15sp" />

                    <EditText
                        android:id="@+id/gender"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="请输入性别"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="horizontal"
                    android:padding="2sp"
                    android:layout_height="wrap_content">

                </LinearLayout>
            </LinearLayout>


            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:padding="2sp"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:textSize="15sp"
                        android:text="年龄:"
                        android:layout_height="wrap_content"/>
                    <EditText
                        android:id="@+id/age"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:textSize="15sp"
                        android:hint="请输入年龄"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:padding="2sp"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:textSize="15sp"
                        android:text="血型:"
                        android:layout_height="wrap_content"/>
                    <EditText
                        android:id="@+id/bloodtype"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:textSize="15sp"
                        android:hint="请输入血型"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/connectuserinfoview"
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/scanusercode"
                android:layout_width="wrap_content"
                android:src="@drawable/scanqrcode"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/binduserinfo"
                android:layout_width="wrap_content"
                android:text="扫码关联伤员"
                android:textSize="20sp"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
