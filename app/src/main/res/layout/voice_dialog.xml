<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:padding="5sp"
    android:layout_height="match_parent">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_height="match_parent">


            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="vertical"
                    android:layout_margin="5sp"
                    android:layout_weight="2"

                    android:layout_height="match_parent">
                    <TextView
                        android:layout_width="match_parent"
                        android:text="检测结果"
                        android:gravity="center"
                        android:layout_height="wrap_content"/>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:orientation="vertical"

                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:orientation="horizontal"
                            android:background="@drawable/underline"
                            android:layout_height="wrap_content">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:orientation="vertical"
                                android:layout_height="wrap_content">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:text="伤部："
                                    android:layout_height="wrap_content"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:id="@+id/addinjuredarea"
                                    android:text="添加"
                                    android:background="@color/bgs6"
                                    android:paddingLeft="5sp"
                                    android:paddingRight="5sp"
                                    android:layout_height="wrap_content"/>
                            </LinearLayout>

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/injuredarea"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"/>

                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:orientation="horizontal"
                            android:background="@drawable/underline"
                            android:layout_height="wrap_content">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:text="伤型："
                                    android:layout_height="wrap_content"/>
                                <TextView
                                    android:id="@+id/addinjuredtype"
                                    android:layout_width="wrap_content"
                                    android:text="添加"
                                    android:paddingLeft="5sp"
                                    android:paddingRight="5sp"
                                    android:background="@color/bgs6"
                                    android:layout_height="wrap_content"/>
                            </LinearLayout>

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/injuredtype"
                                android:layout_width="wrap_content"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"/>

                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:orientation="horizontal"
                            android:background="@drawable/underline"
                            android:layout_height="wrap_content">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:orientation="vertical"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:text="伤类："
                                    android:layout_height="wrap_content"/>

                                <TextView
                                    android:id="@+id/addinjuredser"
                                    android:layout_width="wrap_content"
                                    android:text="添加"
                                    android:paddingLeft="5sp"
                                    android:paddingRight="5sp"
                                    android:background="@color/bgs6"
                                    android:layout_height="wrap_content"/>
                            </LinearLayout>
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/injuredser"
                                android:layout_width="wrap_content"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:orientation="horizontal"
                            android:background="@drawable/underline"
                            android:layout_height="wrap_content">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:orientation="vertical"
                                android:layout_height="wrap_content">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:text="并发症："
                                    android:layout_height="wrap_content"/>
                                <TextView
                                    android:id="@+id/addcomprehan"
                                    android:layout_width="wrap_content"
                                    android:text="添加"
                                    android:paddingLeft="5sp"
                                    android:paddingRight="5sp"
                                    android:background="@color/bgs6"
                                    android:layout_height="wrap_content"/>
                            </LinearLayout>

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/comprehan_recy"
                                android:layout_width="wrap_content"
                                android:layout_weight="1"
                                android:layout_height="wrap_content">


                            </androidx.recyclerview.widget.RecyclerView>



                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:orientation="horizontal"
                            android:background="@drawable/underline"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:text="伤情："
                                android:layout_height="wrap_content"/>
                            <androidx.recyclerview.widget.RecyclerView
                                android:layout_width="wrap_content"
                                android:layout_weight="1"
                                android:id="@+id/injureddeg"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="vertical"
                    android:layout_weight="3"
                    android:layout_margin="5sp"

                    android:layout_height="match_parent">
                    <TextView
                        android:layout_width="match_parent"
                        android:text="语音内容识别"
                        android:gravity="center"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/input"
                        android:background="@drawable/underline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ems="10"
                        android:textSize="12sp"
                        android:lines="15"

                        android:gravity="center"
                        android:inputType="textMultiLine" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:orientation="horizontal"
                        android:layout_margin="5sp"
                        android:gravity="center_horizontal"
                        android:layout_height="wrap_content">


                        <TextView
                            android:id="@+id/voiceinput"
                            android:layout_width="wrap_content"
                            android:text="语音输入(长按说话)"
                            android:layout_margin="3sp"
                            android:gravity="center"

                            android:padding="10sp"
                            android:background="@drawable/btnstyle6"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:id="@+id/confirm"
                            android:layout_width="wrap_content"
                            android:text="确认"
                            android:layout_margin="3sp"
                            android:padding="10sp"
                            android:background="@drawable/btnstyle5"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:id="@+id/cancel"
                            android:layout_width="wrap_content"
                            android:text="关闭"
                            android:padding="10sp"
                            android:layout_margin="3sp"
                            android:background="@drawable/btnstyle3"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>